{
  "drive_root_folder": "Mitra Documents",
  "categories": {
    "kyc": {
      "keywords": ["aadhaar", "aadhar", "pan card", "pan number", "passport", "voter id", "driving license", "dl", "identity proof", "address proof"],
      "folder_pattern": "kyc/{person_name}/{document_type}",
      "file_naming": "{document_type}_{person_name}_{date}"
    },
    "insurance": {
      "keywords": ["policy", "premium", "claim", "coverage", "nominee", "sum assured", "insurance", "lic", "term plan", "health plan", "motor insurance"],
      "folder_pattern": "insurance/{person_name}/{insurance_type}",
      "file_naming": "{insurance_type}_{provider}_{date}"
    },
    "financial": {
      "keywords": ["bank statement", "credit card statement", "salary slip", "pay slip", "form 16", "form 26as", "itr", "tax return", "investment", "portfolio"],
      "folder_pattern": "financial/{document_type}/{year}",
      "file_naming": "{document_type}_{provider}_{period}"
    },
    "medical": {
      "keywords": ["prescription", "lab report", "blood test", "x-ray", "mri", "ct scan", "diagnosis", "medical bill", "hospital", "doctor"],
      "folder_pattern": "medical/{person_name}/{report_type}",
      "file_naming": "{report_type}_{provider}_{date}"
    },
    "legal": {
      "keywords": ["agreement", "contract", "noc", "affidavit", "power of attorney", "will", "deed", "registration", "stamp paper"],
      "folder_pattern": "legal/{document_type}",
      "file_naming": "{document_type}_{party}_{date}"
    },
    "education": {
      "keywords": ["certificate", "marksheet", "mark sheet", "degree", "transcript", "diploma", "convocation", "admit card", "result"],
      "folder_pattern": "education/{institution}/{document_type}",
      "file_naming": "{document_type}_{institution}_{year}"
    },
    "bills_receipts": {
      "keywords": ["invoice", "receipt", "bill", "payment confirmation", "booking confirmation", "ticket", "voucher"],
      "folder_pattern": "bills/{category}/{year}/{month}",
      "file_naming": "{vendor}_{amount}_{date}"
    }
  },
  "supported_formats": [".pdf", ".jpg", ".jpeg", ".png", ".doc", ".docx", ".xls", ".xlsx"],
  "max_file_size_mb": 25
}
