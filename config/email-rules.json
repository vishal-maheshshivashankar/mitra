  "malicious_indicators": {
    "phishing_patterns": [
      "verify your account immediately",
      "your account has been compromised",
      "click here to unlock",
      "suspended.*account",
      "update.*payment.*information",
      "confirm.*identity.*within.*hours",
      "unusual.*activity.*detected"
    ],
    "suspicious_attachment_types": [
      ".exe", ".scr", ".js", ".vbs", ".bat", ".cmd",
      ".ps1", ".msi", ".jar", ".com", ".pif"
    ],
    "suspicious_sender_patterns": [
      "noreply.*@.*(?!google|amazon|flipkart|hdfc|icici|axis|sbi|kotak)",
      ".*@.*\\.ru$",
      ".*@.*\\.cn$",
      ".*@.*\\.tk$"
    ],
    "urgency_phrases": [
      "act now", "urgent", "immediately", "within 24 hours",
      "account will be closed", "last warning", "final notice"
    ]
  },
  "priority_rules": {
    "high": [
