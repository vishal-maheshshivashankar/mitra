# ============================================================
# MITRA AI CHATBOT - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ─── General ─────────────────────────────────────────────────
TIMEZONE=Asia/Kolkata

# ─── N8N Configuration ──────────────────────────────────────
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ─── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=n8n
POSTGRES_PASSWORD=CHANGE_ME_secure_postgres_password
POSTGRES_DB=mitra_n8n

# ─── Telegram Bot ────────────────────────────────────────────
# Create bot via @BotFather on Telegram
# 1. Open Telegram, search @BotFather
# 2. Send /newbot, follow prompts
# 3. Copy the token here
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
# Your Telegram user chat ID (send /start to @userinfobot to get it)
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# ─── Google Cloud / APIs ────────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create a new project (or use existing)
# 3. Enable APIs: Gmail, Google Drive, Google Sheets, Google Calendar
# 4. Create OAuth 2.0 credentials (Desktop app type)
# 5. Create Service Account for Sheets/Drive
GOOGLE_SERVICE_ACCOUNT_FILE=/credentials/google-service-account.json

# Gmail OAuth (for both accounts)
GMAIL_CLIENT_ID=YOUR_GMAIL_CLIENT_ID
GMAIL_CLIENT_SECRET=YOUR_GMAIL_CLIENT_SECRET

# Gmail Account 1: vishal.maheshshivashankar@gmail.com
GMAIL_REFRESH_TOKEN_1=YOUR_REFRESH_TOKEN_ACCOUNT_1
# Gmail Account 2: vishalre411@gmail.com
GMAIL_REFRESH_TOKEN_2=YOUR_REFRESH_TOKEN_ACCOUNT_2

# ─── Gemini AI ───────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# ─── Google Sheets ───────────────────────────────────────────
# Created by setup-sheets.py script
SPREADSHEET_ID=YOUR_SPREADSHEET_ID

# ─── Health Bridge ───────────────────────────────────────────
HEALTH_BRIDGE_URL=http://health-bridge:8085
# Internal API key for health bridge (auto-generated by make setup)
HEALTH_BRIDGE_API_KEY=CHANGE_ME_health_bridge_key
# Bind: 0.0.0.0 for iPhone access, 127.0.0.1 for local only
HEALTH_BRIDGE_BIND=0.0.0.0

# ─── Logging ────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Optional: OpenAI (if using GPT as fallback) ────────────
# OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# ─── SECURITY NOTE ──────────────────────────────────────────
# Protect this file: chmod 600 .env
# NEVER commit this file to version control
