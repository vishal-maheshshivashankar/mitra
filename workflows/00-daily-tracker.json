    {
      "parameters": {
        "jsCode": "const raw = ($input.first().json.message.text || '');\nconst text = raw.replace(/^\\/water\\s*/i, '').toLowerCase();\nconst chatId = $input.first().json.message.chat.id;\nconst numMatch = text.match(/([\\d.]+)/);\nlet ml;\nif (numMatch) {\n  const num = parseFloat(numMatch[1]);\n  ml = num < 20 ? Math.round(num * 250) : Math.round(num);\n} else {\n  ml = 250;\n}\nif (ml < 50) ml = 50;\nif (ml > 2000) ml = 2000;\nconst now = new Date();\nreturn [{ json: {\n  chat_id: chatId, ml,\n  date: now.toISOString().split('T')[0],\n  time: now.toTimeString().split(' ')[0]\n}}];"
      },
