    {
      "parameters": {
        "jsCode": "const uploadResp = $input.first().json;\nconst fileUri = uploadResp?.file?.uri;\nconst mimeType = uploadResp?.file?.mimeType || 'image/jpeg';\n\nif (!fileUri) {\n  throw new Error('Gemini Files upload failed. Response: ' + JSON.stringify(uploadResp).substring(0, 500));\n}\n\nconst caption = $('Telegram Trigger').first().json.message.caption || '';\nconst userHint = caption ? '\\n\\nUser note: \"' + caption + '\"' : '';\n\nconst prompt = 'Analyze this food image and return ONLY valid JSON, no markdown, no explanation.' + userHint + '\\n\\nReturn this exact structure:\\n{\\n  \"meal_type\": \"lunch\",\\n  \"items\": [{\"name\": \"Dal Rice\", \"portion\": \"1 bowl\", \"calories\": 350, \"protein\": 12, \"carbs\": 55, \"fat\": 8, \"sugar\": 3, \"fiber\": 6}],\\n  \"totals\": {\"calories\": 350, \"protein\": 12, \"carbs\": 55, \"fat\": 8, \"sugar\": 3, \"fiber\": 6},\\n  \"health_rating\": 4,\\n  \"notes\": \"Brief comment\"\\n}';\n\nconst geminiBody = {\n  contents: [{\n    parts: [\n      { fileData: { fileUri, mimeType } },\n      { text: prompt }\n    ]\n  }],\n  generationConfig: { temperature: 0.3, maxOutputTokens: 8192 }\n};\n\nreturn [{ json: { geminiBody, fileUri } }];"
      },
