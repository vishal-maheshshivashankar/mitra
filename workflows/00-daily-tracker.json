      "id": "read-water-today",
      "name": "Read Today Water",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [
        1100,
        300
      ],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "gsheets001",
          "name": "Google Sheets"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const today = new Date().toISOString().split('T')[0];\nconst rows = $input.all();\nconst todayTotal = rows\n  .filter(r => r.json.date === today)\n  .reduce((sum, r) => sum + (parseFloat(r.json.ml) || 0), 0);\n\nconst target = 3000;\nconst remaining = Math.max(0, target - todayTotal);\nconst percent = Math.round((todayTotal / target) * 100);\n// Bar: 10 squares, each = 200ml\nconst filled = Math.min(Math.floor(todayTotal / 200), 10);\nlet bar = '';\nfor (let i = 0; i < 10; i++) bar += i < filled ? '🟦' : '⬜';\n\nlet msg = `💧 *Water logged!*\\n\\n${bar}\\nToday: *${todayTotal}ml / ${target}ml* (${percent}%)`;\nif (remaining > 0) msg += `\\n${remaining}ml more to reach your goal!`;\nelse msg += `\\n🎉 Daily water goal reached!`;\n\nconst chatId = $('Parse Water Command').first().json.chat_id;\nreturn [{ json: { reply: msg, chat_id: chatId } }];"
      },
