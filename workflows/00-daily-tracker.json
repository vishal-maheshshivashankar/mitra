      "id": "gemini-analyze",
      "name": "Gemini Food Analysis",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1320,
        100
      ]
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst chatId = $('Telegram Trigger').first().json.message.chat.id;\nconst esc = s => String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');\n\n// Capture actual Gemini API errors (neverError:true keeps them out of node errors)\nif (raw.error) {\n  const msg = raw.error.message || JSON.stringify(raw.error).substring(0, 300);\n  const status = raw.error.status || raw.error.code || '?';\n  return [{ json: {\n    reply: `❌ <b>Gemini error [${esc(String(status))}]:</b>\\n${esc(msg)}`,\n    chat_id: chatId,\n    meal_id: '', date: new Date().toISOString().split('T')[0],\n    time: new Date().toTimeString().split(' ')[0],\n    meal_type: 'error', food_items: 'gemini_error',\n    calories: 0, protein_g: 0, carbs_g: 0, fat_g: 0, sugar_g: 0, fiber_g: 0\n  }}];\n}\n\nconst text = raw.candidates?.[0]?.content?.parts?.[0]?.text || '{}';\n\nlet parsed;\ntry {\n  const clean = text.replace(/```json\\n?|```/g, '').trim();\n  const match = clean.match(/\\{[\\s\\S]*\\}/);\n  parsed = match ? JSON.parse(match[0]) : {};\n} catch(e) {\n  parsed = {};\n}\n\nconst now = new Date();\nconst mealId = 'meal_' + now.getTime();\nconst items = (parsed.items || []).map(i => `• ${esc(i.name)} (${esc(i.portion)}): ${i.calories} kcal`).join('\\n');\nconst t = parsed.totals || {};\nconst sugarAlert = (t.sugar || 0) > 24 ? `\\n\\n⚠️ High sugar: ${t.sugar}g (limit: 30g/day)` : '';\nconst stars = '⭐'.repeat(Math.min(parsed.health_rating || 3, 5));\n\nconst reply = `🍽️ <b>Meal Logged!</b>\\n\\n${items}\\n\\n<b>Totals:</b>\\nCalories: ${t.calories || 0} kcal\\nProtein: ${t.protein || 0}g | Carbs: ${t.carbs || 0}g | Fat: ${t.fat || 0}g\\n\\nHealth: ${stars}\\n💡 ${esc(parsed.notes || '')}${sugarAlert}`;\n\nreturn [{ json: {\n  reply,\n  chat_id: chatId,\n  meal_id: mealId,\n  date: now.toISOString().split('T')[0],\n  time: now.toTimeString().split(' ')[0],\n  meal_type: parsed.meal_type || 'meal',\n  food_items: (parsed.items || []).map(i => i.name).join(', '),\n  calories: t.calories || 0,\n  protein_g: t.protein || 0,\n  carbs_g: t.carbs || 0,\n  fat_g: t.fat || 0,\n  sugar_g: t.sugar || 0,\n  fiber_g: t.fiber || 0\n}}];"
      },
