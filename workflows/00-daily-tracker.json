        "jsCode": "const msg = $input.first().json.message;\nconst foodText = (msg.text || '').replace(/^\\/food\\s*/i, '').trim();\n\nconst prompt = 'You are a nutrition expert. Analyze the following food description and return ONLY valid JSON, no markdown, no explanation.\\n\\nFood description: \"' + foodText + '\"\\n\\nReturn this exact structure:\\n{\\n  \"meal_type\": \"lunch\",\\n  \"items\": [{\"name\": \"Dal Rice\", \"portion\": \"1 bowl\", \"calories\": 350, \"protein\": 12, \"carbs\": 55, \"fat\": 8, \"sugar\": 3, \"fiber\": 6}],\\n  \"totals\": {\"calories\": 350, \"protein\": 12, \"carbs\": 55, \"fat\": 8, \"sugar\": 3, \"fiber\": 6},\\n  \"health_rating\": 4,\\n  \"notes\": \"Brief comment\"\\n}\\n\\nIf the text is not a food description, return:\\n{\"items\": [], \"totals\": {\"calories\": 0, \"protein\": 0, \"carbs\": 0, \"fat\": 0, \"sugar\": 0, \"fiber\": 0}, \"meal_type\": \"unknown\", \"health_rating\": 0, \"notes\": \"Not recognised as food. Type /food [what you ate] or send a photo.\"}';\n\nconst geminiBody = {\n  contents: [{ parts: [{ text: prompt }] }],\n  generationConfig: { temperature: 0.3, maxOutputTokens: 8192 }\n};\n\nreturn [{ json: { geminiBody } }];"
      },
