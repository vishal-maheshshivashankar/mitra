    {
      "parameters": {
        "jsCode": "const today = new Date().toISOString().split('T')[0];\nconst text = ($('Telegram Trigger').first().json.message.text || '').toLowerCase();\n\nlet days = 1, periodLabel = 'Today';\nif (text.includes('month')) { days = 30; periodLabel = 'This Month (30 days)'; }\nelse if (text.includes('week')) { days = 7; periodLabel = 'This Week (7 days)'; }\n\nconst startDate = new Date();\nstartDate.setDate(startDate.getDate() - (days - 1));\nconst startDateStr = startDate.toISOString().split('T')[0];\nconst inRange = d => d >= startDateStr && d <= today;\n\nconst rows = $input.all().filter(r => inRange(r.json.date));\nconst target = 3000 * days;\nconst total = rows.reduce((s, r) => s + (parseFloat(r.json.ml) || 0), 0);\nconst pct = Math.round((total / target) * 100);\n\nconst filled = Math.min(Math.floor((total / target) * 10), 10);\nlet bar = ''; for (let i = 0; i < 10; i++) bar += i < filled ? '🟦' : '⬜';\n\nconst chatId = $('Telegram Trigger').first().json.message.chat.id;\nconst dateRange = days === 1\n  ? new Date().toLocaleDateString('en-IN', { weekday: 'long', day: 'numeric', month: 'short' })\n  : `${startDateStr} → ${today}`;\n\nlet msg = `💧 *Water Summary — ${periodLabel}*\\n_${dateRange}_\\n\\n${bar}\\n`;\n\nif (days > 1) {\n  msg += `Total: *${total}ml* | Avg: *${Math.round(total / days)}ml/day*\\n`;\n  msg += `Target: ${target}ml (${pct}%)`;\n} else {\n  msg += `${total}ml / ${target}ml (${pct}%)`;\n  const remaining = Math.max(0, target - total);\n  if (remaining > 0) msg += `\\n${remaining}ml more to reach your goal!`;\n  else msg += `\\n🎉 Daily water goal reached!`;\n}\n\nif (days === 1 && rows.length > 0) {\n  const logs = rows.map(r => `  • ${r.json.time}: ${r.json.ml}ml`).join('\\n');\n  msg += `\\n\\n🕐 *Logs (${rows.length})*\\n${logs}`;\n}\n\nreturn [{ json: { reply: msg, chat_id: chatId } }];"
      },
