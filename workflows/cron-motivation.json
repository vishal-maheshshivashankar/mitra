{
  "name": "Cron - Daily Motivation (6:30AM) + Weekly Review (Sun 8PM)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "cronExpression", "expression": "30 6 * * *" }]
        }
      },
      "id": "morning-schedule",
      "name": "Daily 6:30AM",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [220, 200]
    },
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "cronExpression", "expression": "0 20 * * 0" }]
        }
      },
      "id": "weekly-schedule",
      "name": "Sunday 8PM",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [220, 500]
    },
    {
      "parameters": {
        "operation": "read",
        "documentId": { "__rl": true, "mode": "id", "value": "={{ $env.SPREADSHEET_ID }}" },
        "sheetName": { "__rl": true, "mode": "name", "value": "Todos" },
        "options": {}
      },
      "id": "read-todos-daily",
      "name": "Read Todos (Daily)",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [440, 120],
      "credentials": {
        "googleSheetsOAuth2Api": { "id": "google-sheets", "name": "Google Sheets" }
      }
    },
    {
      "parameters": {
        "operation": "read",
        "documentId": { "__rl": true, "mode": "id", "value": "={{ $env.SPREADSHEET_ID }}" },
        "sheetName": { "__rl": true, "mode": "name", "value": "Meals" },
        "options": {}
      },
      "id": "read-meals-daily",
      "name": "Read Meals (Daily)",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [440, 260],
      "credentials": {
        "googleSheetsOAuth2Api": { "id": "google-sheets", "name": "Google Sheets" }
      }
    },
    {
      "parameters": {
        "model": "gemini-2.5-flash",
        "options": { "temperature": 0.8, "maxOutputTokens": 1024 },
        "messages": {
          "values": [
            {
              "content": "Generate a personalized morning motivation message for Vishal.\n\nYesterday's data:\n- Todos: {{ $('Read Todos (Daily)').all().filter(t => t.json.status === 'completed').length }} completed, {{ $('Read Todos (Daily)').all().filter(t => t.json.status === 'pending').length }} pending\n- Meals logged: {{ $('Read Meals (Daily)').all().length }}\n\nCreate a short, energizing morning message that:\n1. Starts with a motivational quote or observation (rotate themes: discipline, consistency, growth, health, wealth)\n2. Acknowledges yesterday's effort (be specific if data available)\n3. Sets 3 focus themes for today (health, productivity, finance - pick relevant ones)\n4. Ends with an encouraging one-liner\n\nKeep it under 200 words. Use emojis naturally. Tone: warm, supportive friend.\nFormat for Telegram Markdown."
            }
          ]
        }
      },
      "id": "daily-motivation",
      "name": "Generate Daily Motivation",
      "type": "@n8n/n8n-nodes-langchain.lmChatGoogleGemini",
      "typeVersion": 1,
      "position": [700, 200],
      "credentials": {
        "googleGeminiApi": { "id": "gemini-api", "name": "Gemini API" }
      }
    },
    {
      "parameters": {
        "chatId": "={{ $env.TELEGRAM_CHAT_ID }}",
        "text": "={{ $json.text }}",
        "additionalFields": { "parse_mode": "Markdown" }
      },
      "id": "send-daily",
      "name": "Send Morning Message",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [940, 200],
      "credentials": {
        "telegramApi": { "id": "telegram-bot", "name": "Mitra Telegram Bot" }
      }
    },
    {
      "parameters": {
        "operation": "read",
        "documentId": { "__rl": true, "mode": "id", "value": "={{ $env.SPREADSHEET_ID }}" },
        "sheetName": { "__rl": true, "mode": "name", "value": "Todos" },
        "options": {}
      },
      "id": "read-todos-weekly",
      "name": "Read Todos (Weekly)",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [440, 420],
      "credentials": {
        "googleSheetsOAuth2Api": { "id": "google-sheets", "name": "Google Sheets" }
